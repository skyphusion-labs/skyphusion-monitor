# Default-setup customization for JS/TS on self-hosted fleet runners.
# TypeScript extraction requires Node on PATH; ephemeral runners do not ship it.
# Advanced setup (codeql.yml) cannot coexist with default setup: SARIF upload is
# rejected with "advanced configurations cannot be processed when default setup
# is enabled".

- name: Setup Node.js
  uses: actions/setup-node@v4
  with:
    node-version: '22'

- name: Install dependencies
  run: npm ci

- name: Initialize CodeQL
  uses: github/codeql-action/init@v4
  with:
    node-version: '22'

- name: Perform CodeQL Analysis
  uses: github/codeql-action/analyze@v4
